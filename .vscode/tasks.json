{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe 生成活动文件",
            "command": "E:/mingw64/bin/g++.exe", 
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "main.cpp",
                "src/ProtocolParser.cpp",
                "src/PcapDumper.cpp",
                "src/PacketStats.cpp",
                "src/SnifferEngine.cpp",
                "-o",
                "${workspaceFolder}\\main.exe",
                "-I", "E:/npcap/Include",
                "-L", "E:/npcap/Lib/x64",
                "-lwpcap",
                "-lPacket",
                "-lws2_32"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ],
    "version": "2.0.0"
}