{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe 生成活动文件",
            "command": "E:/mingw64/bin/g++.exe", 
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                "-I", "E:/npcap/Include",      
                "-L", "E:/npcap/Lib/x64",      
                "-lwpcap",                         
                "-lPacket",
                "-lws2_32" // ➔ 💡 就是在这里，加上这一行链接 Windows 套接字库
            ],
            "options": {
                "cwd": "E:/mingw64/bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ],
    "version": "2.0.0"
}