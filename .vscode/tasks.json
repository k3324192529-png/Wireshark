{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe 生成活动文件",
            "command": "E:/mingw64/bin/g++.exe", 
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                
                // --- 修正后的 Npcap SDK 路径 ---
                "-I", "E:/npcap/npcap-sdk-1.16/Include",      
                "-L", "E:/npcap/npcap-sdk-1.16/Lib/x64",      
                "-lwpcap",                         
                "-lPacket"                         
            ],
            "options": {
                "cwd": "E:/mingw64/bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ],
    "version": "2.0.0"
}